{
  "version": "0.1.0",
  "name": "escrow",
  "instructions": [
    {
      "name": "create",
      "accounts": [
        { "name": "business",      "isMut": true,  "isSigner": true  },
        { "name": "escrow",        "isMut": true,  "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "freelancer",        "type": "publicKey" },
        { "name": "requirementsHash",  "type": { "array": ["u8", 32] } }
      ]
    },
    {
      "name": "deposit",
      "accounts": [
        { "name": "business",      "isMut": true,  "isSigner": true  },
        { "name": "escrow",        "isMut": true,  "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ]
    },
    {
      "name": "submitWork",
      "accounts": [
        { "name": "freelancer", "isMut": true,  "isSigner": true  },
        { "name": "escrow",     "isMut": true,  "isSigner": false }
      ],
      "args": [
        { "name": "workHash", "type": { "array": ["u8", 32] } }
      ]
    },
    {
      "name": "release",
      "accounts": [
        { "name": "business",   "isMut": true, "isSigner": true  },
        { "name": "freelancer", "isMut": true, "isSigner": false },
        { "name": "escrow",     "isMut": true, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "refund",
      "accounts": [
        { "name": "business", "isMut": true, "isSigner": true  },
        { "name": "escrow",   "isMut": true, "isSigner": false }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "EscrowAccount",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "business",          "type": "publicKey" },
          { "name": "freelancer",        "type": "publicKey" },
          { "name": "requirementsHash",  "type": { "array": ["u8", 32] } },
          { "name": "workHash",          "type": { "array": ["u8", 32] } },
          { "name": "amount",            "type": "u64" },
          { "name": "state",             "type": { "defined": "EscrowState" } },
          { "name": "bump",              "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "EscrowState",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Created"       },
          { "name": "Funded"        },
          { "name": "WorkSubmitted" },
          { "name": "Released"      },
          { "name": "Refunded"      }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "InvalidState",  "msg": "Operation not allowed in current state" },
    { "code": 6001, "name": "Unauthorized",  "msg": "Caller is not authorized" },
    { "code": 6002, "name": "ZeroAmount",    "msg": "Deposit amount must be greater than zero" }
  ]
}
